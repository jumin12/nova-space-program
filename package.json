{
  "name": "orbital-frontier",
  "private": true,
  "version": "0.1.0",
  "description": "Orbital Frontier — Stage 0 browser prototype",
  "scripts": {
    "predev": "pnpm --filter @orbital/common build && pnpm --filter @orbital/physics build",
    "dev": "pnpm --parallel --filter @orbital/client --filter @orbital/server dev",
    "start": "pnpm dev",
    "dev:client": "pnpm --filter @orbital/client dev",
    "dev:server": "pnpm --filter @orbital/server dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @orbital/physics test",
    "test:integration": "node scripts/integration-test.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
